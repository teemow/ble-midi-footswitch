// Copy this file to secrets.h and set your own values. secrets.h is gitignored
// and never committed. If absent, main.cpp falls back to insecure defaults.
#pragma once

#define OTA_PASSWORD "changeme-ota"   // ArduinoOTA upload auth
#define AP_PASSWORD  "changeme-ap"    // WiFiManager captive-portal passphrase

// Known WiFi networks the footswitch roams between (home, practice room, ...).
// On boot WiFiMulti scans and joins the strongest reachable one, so the same
// firmware works at every location with no reconfiguration. Add one WIFI_NET
// line per network; order does not matter (selection is by signal strength).
#define WIFI_NETWORKS \
  WIFI_NET("home-ssid", "home-password") \
  WIFI_NET("practice-room-ssid", "practice-room-password")
